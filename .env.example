# Required for JWT signing — set a long random string in Vercel env settings
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES=8h

# Vercel Postgres injects these automatically when you attach the DB:
# POSTGRES_URL=
# POSTGRES_PRISMA_URL=
# POSTGRES_URL_NON_POOLING=
# POSTGRES_USER=
# POSTGRES_HOST=
# POSTGRES_PASSWORD=
# POSTGRES_DATABASE=

# Optional: lock CORS to your published domain
# CLIENT_ORIGIN=https://seedlynx.vercel.app
